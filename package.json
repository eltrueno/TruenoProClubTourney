{
  "name": "trueno-pro-club-tourney",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:backend": "pnpm --filter @trueno-pro-club-tourney/backend dev",
    "dev:frontend": "pnpm --filter @trueno-pro-club-tourney/frontend dev",
    "build:shared": "pnpm --filter @trueno-pro-club-tourney/shared build",
    "build:backend": "pnpm --filter @trueno-pro-club-tourney/backend build",
    "build:frontend": "pnpm --filter @trueno-pro-club-tourney/frontend build",
    "build": "pnpm build:shared && pnpm build:backend && pnpm build:frontend"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}