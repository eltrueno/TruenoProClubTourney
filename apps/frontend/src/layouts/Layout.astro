---
import "../styles/global.css";
import NavLinks from "../components/NavLinks.vue";
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es" data-theme="mundial">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · TruenoProClubTourney</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-base-200 text-base-content">
    <nav class="navbar bg-base-100 shadow-sm sticky top-0 z-50 px-4">
      <div class="flex-1">
        <a href="/" class="btn btn-ghost gap-2 text-lg font-black">
          ⚽ <span class="hidden sm:inline">TruenoProClubTourney</span>
        </a>
      </div>
      <NavLinks client:load />
    </nav>
    <main class="max-w-5xl mx-auto p-4 md:p-6">
      <slot />
    </main>
  </body>
</html>
